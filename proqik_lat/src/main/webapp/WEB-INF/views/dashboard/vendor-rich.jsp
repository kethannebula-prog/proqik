<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.util.*" %>
<%@ page import="java.text.SimpleDateFormat" %>
<%@ page import="java.util.Map" %>
<%@ page import="java.util.List" %>
<%
String vendorName = (String) request.getAttribute("vendorName");
String vendorCategory = (String) request.getAttribute("vendorCategory");
String vendorLocation = (String) request.getAttribute("vendorLocation");
String vendorPhone = (String) request.getAttribute("vendorPhone");
String vendorBusiness = (String) request.getAttribute("vendorBusiness");
String vendorStatus = (String) request.getAttribute("vendorStatus");
String vendorEarnings = (String) request.getAttribute("vendorEarnings");
String vendorBookingCount = (String) request.getAttribute("vendorBookingCount");
String vendorRating = (String) request.getAttribute("vendorRating");

if (vendorName == null) vendorName = (String) session.getAttribute("userName");
if (vendorName == null || vendorName.isEmpty()) vendorName = "Vendor";
if (vendorCategory == null || vendorCategory.isEmpty()) vendorCategory = "Photography";
if (vendorLocation == null || vendorLocation.isEmpty()) vendorLocation = "Not set";
if (vendorPhone == null || vendorPhone.isEmpty()) vendorPhone = "Not provided";
if (vendorBusiness == null || vendorBusiness.isEmpty()) vendorBusiness = "Not provided";
if (vendorStatus == null) vendorStatus = "incomplete";
if (vendorEarnings == null) vendorEarnings = "0";
if (vendorBookingCount == null) vendorBookingCount = "0";
if (vendorRating == null || vendorRating.equals("0")) vendorRating = "New";

String userEmail = (String) session.getAttribute("user");
boolean isActive = "complete".equals(vendorStatus) || "active".equals(vendorStatus);

List<Map<String, Object>> svcList = (List<Map<String, Object>>) request.getAttribute("vendorServices");
if (svcList == null) svcList = new ArrayList<>();

List<Map<String, Object>> bkList = (List<Map<String, Object>>) request.getAttribute("vendorBookings");
if (bkList == null) bkList = new ArrayList<>();

String heroInitials = vendorName.length() > 0 ? vendorName.substring(0,1).toUpperCase() : "V";
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= vendorName %> - Provider Dashboard | ProQik</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --navy-deep: #0a1628;
            --navy: #1b376c;
            --navy-mid: #234a8c;
            --navy-light: #2a5090;
            --gold: #D4A574;
            --gold-light: #e2c094;
            --gold-dark: #c49563;
            --cream: #faf8f5;
            --ivory: #f7f5f0;
            --white: #ffffff;
            --text-dark: #1a1a2e;
            --text-soft: #4a4a5a;
            --text-muted: #8e8e9a;
            --border: #e8e4de;
            --border-light: #f0ece6;
            --success: #2e7d32;
            --success-bg: #e8f5e9;
            --shadow-sm: 0 2px 8px rgba(10,22,40,0.04);
            --shadow-md: 0 8px 32px rgba(10,22,40,0.08);
            --shadow-lg: 0 16px 48px rgba(10,22,40,0.12);
            --shadow-xl: 0 24px 64px rgba(10,22,40,0.16);
            --shadow-gold: 0 8px 32px rgba(212,165,116,0.2);
            --radius-sm: 6px;
            --radius: 12px;
            --radius-lg: 20px;
            --radius-xl: 28px;
            --transition: 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        }

        body {
            font-family: 'Lato', sans-serif;
            background: var(--cream);
            color: var(--text-dark);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }

        img {
            max-width: 100%;
            display: block;
        }

        ::selection {
            background: var(--gold);
            color: var(--navy-deep);
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--cream); }
        ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

        /* ====== TOP BAR ====== */
        .top-bar {
            background: var(--navy-deep);
            color: rgba(255,255,255,0.85);
            padding: 10px 0;
            font-size: 12px;
            letter-spacing: 0.3px;
            border-bottom: 1px solid rgba(212,165,116,0.15);
        }

        .top-bar .container {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .top-contact {
            display: flex;
            gap: 28px;
            flex-wrap: wrap;
            align-items: center;
        }

        .top-contact-item {
            display: flex;
            align-items: center;
            gap: 8px;
            opacity: 0.8;
            transition: opacity var(--transition);
        }

        .top-contact-item:hover {
            opacity: 1;
        }

        .top-contact-item svg {
            width: 14px;
            height: 14px;
            color: var(--gold);
        }

        .top-bar .container > div:last-child {
            font-weight: 600;
            color: var(--gold);
            font-size: 11px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        /* ====== HEADER ====== */
        header {
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-container {
            max-width: 1320px;
            margin: 0 auto;
            padding: 18px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 30px;
            font-weight: 700;
            color: var(--navy);
            letter-spacing: -0.3px;
        }

        .logo span {
            color: var(--gold);
        }

        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 4px;
            padding: 6px;
            cursor: pointer;
            background: none;
            border: 2px solid var(--navy);
            border-radius: var(--radius-sm);
            transition: border-color var(--transition);
        }

        .menu-toggle span {
            width: 22px;
            height: 2.5px;
            background: var(--navy);
            border-radius: 2px;
            transition: all var(--transition);
        }

        nav {
            display: flex;
            gap: 6px;
            align-items: center;
            flex-wrap: wrap;
        }

        nav a {
            color: var(--text-soft);
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            padding: 8px 16px;
            border-radius: var(--radius);
            transition: all var(--transition);
            letter-spacing: 0.2px;
        }

        nav a:hover {
            color: var(--navy);
            background: rgba(27,55,108,0.05);
        }

        .nav-btn {
            background: var(--navy) !important;
            color: #fff !important;
            padding: 10px 24px !important;
            border-radius: var(--radius) !important;
            font-weight: 600 !important;
            letter-spacing: 0.5px;
        }

        .nav-btn:hover {
            background: var(--navy-mid) !important;
            box-shadow: var(--shadow-sm) !important;
        }

        .logout-btn {
            background: transparent !important;
            color: #c0392b !important;
            border: 1px solid #c0392b !important;
            margin-left: 8px;
        }

        .logout-btn:hover {
            background: #c0392b !important;
            color: #fff !important;
            border-color: #c0392b !important;
        }

        /* ====== MAIN CONTENT ====== */
        .main-content {
            max-width: 1320px;
            margin: 0 auto;
            padding: 48px 24px;
        }

        /* ====== DASHBOARD GRID ====== */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 32px;
            margin-bottom: 56px;
        }

        /* ====== WELCOME SECTION ====== */
        .welcome-section {
            background: var(--white);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 48px 52px;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .welcome-section::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(212,165,116,0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .welcome-section h1 {
            font-family: 'Playfair Display', serif;
            font-size: 44px;
            font-weight: 600;
            color: var(--navy);
            line-height: 1.15;
            margin-bottom: 16px;
            position: relative;
        }

        .welcome-section h1 span {
            color: var(--gold);
            font-style: italic;
        }

        .welcome-section p {
            font-size: 16px;
            color: var(--text-soft);
            margin-bottom: 32px;
            line-height: 1.8;
            max-width: 560px;
            position: relative;
        }

        .welcome-buttons {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            position: relative;
        }

        .btn-primary {
            background: var(--navy);
            color: #fff;
            padding: 14px 32px;
            text-decoration: none;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all var(--transition);
            border: none;
            cursor: pointer;
            letter-spacing: 0.3px;
        }

        .btn-primary:hover {
            background: var(--navy-mid);
            box-shadow: var(--shadow-gold);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background: transparent;
            color: var(--navy);
            padding: 14px 32px;
            text-decoration: none;
            border-radius: var(--radius);
            font-weight: 600;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 2px solid var(--navy);
            transition: all var(--transition);
            letter-spacing: 0.3px;
        }

        .btn-secondary:hover {
            background: var(--navy);
            color: #fff;
            transform: translateY(-2px);
        }

        /* ====== DASHBOARD CARD ====== */
        .dashboard-card {
            background: var(--white);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 36px;
            box-shadow: var(--shadow-lg);
            transition: box-shadow var(--transition);
        }

        .dashboard-card:hover {
            box-shadow: var(--shadow-xl);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 28px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
            flex-wrap: wrap;
            gap: 12px;
        }

        .user-info {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .user-avatar {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: 3px solid var(--gold);
            object-fit: cover;
            box-shadow: 0 0 0 4px rgba(212,165,116,0.15);
        }

        .user-avatar-text {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: linear-gradient(145deg, var(--navy), var(--navy-mid));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            font-weight: 800;
            color: #fff;
            border: 3px solid var(--gold);
            box-shadow: 0 0 0 4px rgba(212,165,116,0.15);
            flex-shrink: 0;
            font-family: 'Playfair Display', serif;
        }

        .user-details h3 {
            font-size: 18px;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 2px;
        }

        .user-details p {
            font-size: 13px;
            color: var(--text-muted);
        }

        .status-pill {
            background: var(--success-bg);
            color: var(--success);
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            letter-spacing: 0.3px;
        }

        /* ====== EARNINGS BOX ====== */
        .earnings-box {
            background: linear-gradient(145deg, var(--navy-deep) 0%, var(--navy) 50%, var(--navy-mid) 100%);
            color: #fff;
            padding: 28px 32px;
            border-radius: var(--radius);
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
        }

        .earnings-box::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(212,165,116,0.1) 0%, transparent 60%);
            pointer-events: none;
        }

        .earnings-box::after {
            content: '✦';
            position: absolute;
            bottom: 12px;
            right: 20px;
            font-size: 80px;
            color: rgba(212,165,116,0.08);
            pointer-events: none;
            font-family: serif;
        }

        .earnings-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            opacity: 0.8;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .earnings-amount {
            font-size: 40px;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 6px;
            font-family: 'Playfair Display', serif;
        }

        .earnings-change {
            font-size: 13px;
            color: var(--gold-light);
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 600;
        }

        /* ====== QUICK METRICS ====== */
        .quick-metrics {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }

        .metric {
            text-align: center;
            padding: 18px 12px;
            background: var(--cream);
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            transition: all var(--transition);
            cursor: pointer;
        }

        .metric:hover {
            background: var(--white);
            border-color: var(--gold);
            box-shadow: var(--shadow-sm);
            transform: translateY(-2px);
        }

        .metric-icon {
            width: 36px;
            height: 36px;
            margin: 0 auto 10px;
            opacity: 0.7;
        }

        .metric-icon svg {
            width: 100%;
            height: 100%;
        }

        .metric-value {
            font-size: 26px;
            font-weight: 900;
            color: var(--navy);
            margin-bottom: 2px;
            font-family: 'Playfair Display', serif;
        }

        .metric-label {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            font-weight: 700;
        }

        /* ====== SECTION HEADERS ====== */
        .section-header {
            text-align: center;
            margin-bottom: 44px;
            position: relative;
        }

        .section-header::after {
            content: '';
            display: block;
            width: 60px;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
            margin: 16px auto 0;
        }

        .section-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 38px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 12px;
            letter-spacing: -0.3px;
        }

        .section-header p {
            font-size: 16px;
            color: var(--text-muted);
            font-weight: 400;
        }

        /* ====== SERVICES GRID ====== */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 28px;
            margin-bottom: 64px;
        }

        .service-card {
            background: var(--white);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all var(--transition);
            box-shadow: var(--shadow-sm);
        }

        .service-card:hover {
            box-shadow: var(--shadow-xl);
            transform: translateY(-8px);
            border-color: rgba(212,165,116,0.3);
        }

        .service-img {
            width: 100%;
            height: 240px;
            object-fit: cover;
            transition: transform 0.6s;
        }

        .service-card:hover .service-img {
            transform: scale(1.05);
        }

        .service-body {
            padding: 28px 32px 32px;
        }

        .service-tag {
            background: var(--navy);
            color: #fff;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: inline-block;
            margin-bottom: 14px;
        }

        .service-body h3 {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 10px;
        }

        .service-body p {
            color: var(--text-soft);
            margin-bottom: 18px;
            font-size: 14px;
            line-height: 1.7;
        }

        .service-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 18px;
            border-top: 1px solid var(--border);
        }

        .service-price {
            font-size: 28px;
            font-weight: 900;
            color: var(--gold-dark);
            font-family: 'Playfair Display', serif;
        }

        .service-link {
            color: var(--navy);
            font-weight: 600;
            text-decoration: none;
            font-size: 14px;
            transition: all var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .service-link:hover {
            color: var(--gold-dark);
            gap: 10px;
        }

        /* ====== PORTFOLIO GRID ====== */
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
            margin-bottom: 64px;
        }

        .portfolio-item {
            position: relative;
            height: 360px;
            overflow: hidden;
            border-radius: var(--radius);
            cursor: pointer;
            box-shadow: var(--shadow-md);
        }

        .portfolio-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .portfolio-item:hover img {
            transform: scale(1.08);
        }

        .portfolio-item::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(10,22,40,0.9) 0%, rgba(10,22,40,0.1) 50%, transparent 100%);
            opacity: 0.7;
            transition: opacity var(--transition);
        }

        .portfolio-item:hover::after {
            opacity: 0.9;
        }

        .portfolio-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 32px 28px 28px;
            z-index: 2;
            color: #fff;
            transform: translateY(8px);
            transition: transform var(--transition);
        }

        .portfolio-item:hover .portfolio-overlay {
            transform: translateY(0);
        }

        .portfolio-overlay h4 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 4px;
            font-family: 'Playfair Display', serif;
        }

        .portfolio-overlay p {
            font-size: 12px;
            opacity: 0.8;
            letter-spacing: 0.5px;
        }

        /* ====== PROFILE SECTION ====== */
        .profile-section {
            background: var(--white);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 40px 48px;
            box-shadow: var(--shadow-md);
            margin-bottom: 64px;
        }

        .profile-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 28px;
        }

        .profile-field {
            background: var(--cream);
            padding: 22px 24px;
            border-radius: var(--radius);
            border: 1px solid var(--border-light);
            transition: all var(--transition);
        }

        .profile-field:hover {
            background: var(--white);
            border-color: var(--gold);
            box-shadow: var(--shadow-sm);
        }

        .profile-field-label {
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .profile-field-value {
            font-size: 16px;
            font-weight: 700;
            color: var(--navy);
        }

        /* ====== ULTRA-PREMIUM CTA BANNER ====== */
        .cta-banner {
            background: linear-gradient(145deg, var(--navy-deep) 0%, var(--navy) 50%, var(--navy-mid) 100%);
            padding: 0;
            margin-bottom: 0;
            position: relative;
            overflow: hidden;
            border-bottom: 3px solid var(--gold);
        }

        .cta-banner::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(212,165,116,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 50%, rgba(212,165,116,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.03) 0%, transparent 40%);
            z-index: 1;
        }

        .cta-banner::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, rgba(212,165,116,0.4), transparent);
            z-index: 2;
        }

        .cta-container {
            max-width: 1320px;
            margin: 0 auto;
            position: relative;
            display: grid;
            grid-template-columns: 300px 1fr 300px;
            align-items: flex-end;
            min-height: 420px;
            z-index: 2;
        }

        .cta-person {
            position: relative;
            height: 100%;
            display: flex;
            align-items: flex-end;
        }

        .cta-person.left {
            width: 100%;
            height: 420px;
        }

        .cta-person.left img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: bottom center;
            filter: drop-shadow(0 20px 45px rgba(0,0,0,0.5)) brightness(1.08);
        }

        .cta-content {
            text-align: center;
            position: relative;
            z-index: 2;
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .cta-logo {
            width: 100px;
            height: 100px;
            background: linear-gradient(145deg, #ffffff 0%, #f8f6f2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.8);
            border: 3px solid var(--gold);
            position: relative;
        }

        .cta-logo::before {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            border: 1px solid rgba(212,165,116,0.3);
        }

        .cta-logo svg {
            width: 56px;
            height: 56px;
        }

        .cta-content h2 {
            font-family: 'Playfair Display', serif;
            font-size: 52px;
            font-weight: 700;
            color: var(--gold);
            line-height: 1;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 6px;
            text-shadow: 0 2px 12px rgba(0,0,0,0.3);
        }

        .cta-content p {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 16px;
            line-height: 1.4;
            font-weight: 500;
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .cta-subtitle {
            font-size: 12px;
            font-weight: 600;
            color: rgba(212,165,116,0.7);
            margin-bottom: 24px;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            line-height: 1.5;
        }

        .cta-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn-white {
            background: var(--gold);
            color: var(--navy-deep);
            padding: 14px 40px;
            text-decoration: none;
            border-radius: var(--radius);
            font-weight: 700;
            display: inline-block;
            transition: all var(--transition);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            box-shadow: var(--shadow-gold);
        }

        .btn-white:hover {
            background: var(--gold-light);
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(212,165,116,0.5);
        }

        .btn-outline {
            background: transparent;
            color: var(--gold);
            padding: 14px 40px;
            text-decoration: none;
            border-radius: var(--radius);
            font-weight: 700;
            display: inline-block;
            border: 2px solid var(--gold);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: all var(--transition);
        }

        .btn-outline:hover {
            background: var(--gold);
            color: var(--navy-deep);
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(212,165,116,0.3);
        }

        /* ====== DECORATIVE ASSETS ====== */
        .decorative-assets {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-end;
            padding: 0 20px;
            width: 100%;
            height: 420px;
        }

        .photographer-equipment {
            width: 100%;
            height: 100%;
            animation: subtle-float 10s ease-in-out infinite;
        }

        .photographer-equipment img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            object-position: bottom center;
            filter: drop-shadow(0 20px 45px rgba(0,0,0,0.5)) brightness(1.08);
        }

        @keyframes subtle-float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }

        .deco-circle {
            position: absolute;
            border-radius: 50%;
        }

        .deco-circle-1 {
            width: 100px;
            height: 100px;
            background: rgba(212,165,116,0.08);
            top: 30px;
            right: 10px;
            animation: subtle-pulse 6s ease-in-out infinite;
        }

        .deco-circle-2 {
            width: 60px;
            height: 60px;
            background: rgba(212,165,116,0.06);
            bottom: 100px;
            left: 10px;
            animation: subtle-pulse 7s ease-in-out infinite;
            animation-delay: 1s;
        }

        @keyframes subtle-pulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.2); opacity: 0.15; }
        }

        /* ====== BOOKINGS TABLE ====== */
        .bookings-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

        .bookings-table thead th {
            padding: 14px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border-bottom: 2px solid var(--border);
            background: var(--cream);
        }

        .bookings-table thead th:first-child {
            border-radius: var(--radius-sm) 0 0 0;
        }

        .bookings-table thead th:last-child {
            border-radius: 0 var(--radius-sm) 0 0;
        }

        .bookings-table tbody tr {
            transition: background var(--transition);
        }

        .bookings-table tbody tr:hover {
            background: rgba(212,165,116,0.04);
        }

        .bookings-table tbody td {
            padding: 14px 16px;
            font-size: 14px;
            border-bottom: 1px solid var(--border-light);
        }

        .bk-id {
            font-weight: 700;
            color: var(--navy);
            font-size: 13px;
        }

        .bk-client {
            font-weight: 600;
        }

        .bk-event, .bk-date {
            color: var(--text-soft);
            font-size: 13px;
        }

        .bk-amount {
            font-weight: 700;
            color: var(--gold-dark);
            font-family: 'Playfair Display', serif;
            font-size: 16px;
        }

        .bk-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .bk-status.confirmed {
            background: #dbeafe;
            color: #1e40af;
        }

        .bk-status.completed {
            background: var(--success-bg);
            color: var(--success);
        }

        .bk-status.pending {
            background: #fef3c7;
            color: #92400e;
        }

        /* ====== FOOTER ====== */
        footer {
            background: var(--navy-deep);
            color: #fff;
            padding: 60px 0 28px;
            border-top: 1px solid rgba(212,165,116,0.1);
        }

        .footer-container {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 48px;
            margin-bottom: 40px;
        }

        .footer-brand h3 {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 16px;
            letter-spacing: 1px;
        }

        .footer-brand h3 span {
            color: var(--gold);
        }

        .footer-brand p {
            color: rgba(255,255,255,0.5);
            line-height: 1.8;
            margin-bottom: 24px;
            font-size: 14px;
            max-width: 300px;
        }

        .social-links {
            display: flex;
            gap: 12px;
        }

        .social-link {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition);
            border: 1px solid rgba(212,165,116,0.1);
        }

        .social-link:hover {
            background: var(--gold);
            border-color: var(--gold);
            transform: translateY(-3px);
        }

        .social-link svg {
            width: 18px;
            height: 18px;
            fill: rgba(255,255,255,0.7);
            transition: fill var(--transition);
        }

        .social-link:hover svg {
            fill: var(--navy-deep);
        }

        .footer-section h4 {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--gold);
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section li {
            margin-bottom: 10px;
        }

        .footer-section a {
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            transition: all var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .footer-section a:hover {
            color: var(--gold);
            padding-left: 4px;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 28px;
            border-top: 1px solid rgba(212,165,116,0.1);
            color: rgba(255,255,255,0.3);
            font-size: 13px;
            letter-spacing: 0.5px;
        }

        /* ====== ENTRANCE ANIMATION ====== */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .welcome-section,
        .dashboard-card,
        .section-header,
        .service-card,
        .portfolio-item,
        .profile-section {
            animation: fadeUp 0.6s ease both;
        }

        .service-card:nth-child(1) { animation-delay: 0.1s; }
        .service-card:nth-child(2) { animation-delay: 0.2s; }
        .service-card:nth-child(3) { animation-delay: 0.3s; }

        /* ====== RESPONSIVE 968px ====== */
        @media (max-width: 968px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 32px;
            }

            .welcome-section {
                padding: 32px;
            }

            .welcome-section h1 {
                font-size: 34px;
            }

            nav {
                display: none;
                flex-direction: column;
                width: 100%;
                padding: 16px 0;
                gap: 4px;
            }

            nav.active {
                display: flex;
            }

            .menu-toggle {
                display: flex;
            }

            .services-grid {
                grid-template-columns: 1fr;
            }

            .portfolio-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .cta-container {
                grid-template-columns: 1fr;
                min-height: auto;
            }

            .cta-person.left {
                width: 100%;
                height: 260px;
                margin: 0 auto;
                max-width: 200px;
            }

            .cta-person.left img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                object-position: bottom center;
            }

            .decorative-assets {
                width: 100%;
                height: 260px;
                max-width: 200px;
                margin: 0 auto;
                padding: 0;
            }

            .photographer-equipment {
                width: 100%;
                height: 100%;
            }

            .photographer-equipment img {
                width: 100%;
                height: 100%;
            }

            .cta-content {
                padding: 32px 24px;
            }

            .cta-logo {
                margin: 0 auto 20px;
                width: 80px;
                height: 80px;
            }

            .cta-logo svg {
                width: 48px;
                height: 48px;
            }

            .cta-content h2 {
                font-size: 36px;
                letter-spacing: 4px;
            }

            .cta-content p {
                font-size: 12px;
                letter-spacing: 2px;
            }

            .cta-subtitle {
                font-size: 11px;
            }

            .cta-buttons {
                justify-content: center;
            }

            .profile-section {
                padding: 28px 24px;
            }
        }

        /* ====== RESPONSIVE 640px ====== */
        @media (max-width: 640px) {
            .top-bar .container {
                flex-direction: column;
                text-align: center;
            }

            .top-contact {
                flex-direction: column;
                gap: 6px;
            }

            .header-container {
                padding: 14px 16px;
            }

            .logo {
                font-size: 22px;
            }

            .welcome-section {
                padding: 24px 20px;
            }

            .welcome-section h1 {
                font-size: 28px;
            }

            .welcome-section p {
                font-size: 15px;
            }

            .dashboard-card {
                padding: 24px 20px;
            }

            .quick-metrics {
                grid-template-columns: 1fr;
            }

            .section-header h2 {
                font-size: 28px;
            }

            .section-header p {
                font-size: 14px;
            }

            .services-grid {
                gap: 20px;
            }

            .service-body {
                padding: 20px 24px 24px;
            }

            .service-price {
                font-size: 24px;
            }

            .portfolio-grid {
                grid-template-columns: 1fr;
            }

            .portfolio-item {
                height: 280px;
            }

            .profile-grid {
                grid-template-columns: 1fr;
            }

            .profile-section {
                padding: 24px 16px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            .cta-banner {
                padding: 0;
            }

            .cta-person.left {
                height: 200px;
                max-width: 160px;
            }

            .cta-person.left img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                object-position: bottom center;
            }

            .decorative-assets {
                height: 200px;
                max-width: 160px;
                padding: 0;
            }

            .photographer-equipment {
                width: 100%;
                height: 100%;
            }

            .photographer-equipment img {
                width: 100%;
                height: 100%;
            }

            .cta-content {
                padding: 24px 16px;
            }

            .cta-content h2 {
                font-size: 28px;
                letter-spacing: 3px;
            }

            .cta-content p {
                font-size: 11px;
                letter-spacing: 1.5px;
                margin-bottom: 12px;
            }

            .cta-subtitle {
                font-size: 10px;
                letter-spacing: 2px;
                margin-bottom: 20px;
            }

            .cta-logo {
                width: 60px;
                height: 60px;
                margin-bottom: 16px;
            }

            .cta-logo svg {
                width: 36px;
                height: 36px;
            }

            .cta-buttons {
                flex-direction: column;
                width: 100%;
            }

            .btn-white,
            .btn-outline {
                width: 100%;
                text-align: center;
                padding: 12px 24px;
            }

            .bookings-table thead th,
            .bookings-table tbody td {
                padding: 10px 12px;
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container">
            <div class="top-contact">
                <div class="top-contact-item">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span><%= vendorPhone %></span>
                </div>
                <div class="top-contact-item">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span><%= userEmail != null ? userEmail : "support@proqik.com" %></span>
                </div>
            </div>
            <div><%= isActive ? "Active Provider" : "Pending Approval" %></div>
        </div>
    </div>

    <!-- Header -->
    <header>
        <div class="header-container">
            <div class="logo">PRO<span>QIK</span></div>
            <button class="menu-toggle" onclick="toggleMenu()">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <nav id="mainNav">
                <a href="<%= request.getContextPath() %>/dashboard">Dashboard</a>
                <a href="<%= request.getContextPath() %>/services">Services</a>
                <a href="<%= request.getContextPath() %>/portfolio">Portfolio</a>
                <a href="<%= request.getContextPath() %>/bookings">Bookings</a>
                <a href="<%= request.getContextPath() %>/earnings">Earnings</a>
                <a href="<%= request.getContextPath() %>/messages" class="nav-btn">Messages</a>
                <a href="<%= request.getContextPath() %>/logout" class="nav-btn logout-btn">Logout</a>
            </nav>
        </div>
    </header>

    <!-- Impressive CTA Banner with Real Photos -->
    <section class="cta-banner">
        <div class="cta-container">
            <!-- Left Person - Photographer with Equipment (Real Photo) -->
            <div class="cta-person left">
                <img src="data:image/png;base64," alt="Professional Photographer">
            </div>

            <!-- Center Content -->
            <div class="cta-content">
                <div class="cta-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1b376c" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <h2>PROQIK</h2>
                <p>PHOTOGRAPHY & VIDEOGRAPHY PLATFORM</p>
                <div class="cta-subtitle">PHOTOGRAPHERS & CLIENTS SIGN UP NOW!</div>
                <div class="cta-buttons">
                    <a href="<%= request.getContextPath() %>/bookings" class="btn-white">VIEW BOOKINGS</a>
                    <a href="<%= request.getContextPath() %>/profile" class="btn-outline">MANAGE PROFILE</a>
                </div>
            </div>

            <!-- Right Person - Illustrated Photographer -->
            <div class="decorative-assets">
                <div class="photographer-equipment">
                    <img src="data:image/png;base64," alt="Photographer Illustration">
                </div>
                <div class="deco-circle deco-circle-1"></div>
                <div class="deco-circle deco-circle-2"></div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Welcome Section -->
            <div class="welcome-section">
                <h1><%= vendorBusiness %> <span>Services Excellence</span></h1>
                <p>Welcome back, <%= vendorName %>! Manage your <%= vendorCategory %> services, view bookings, and grow your business with ProQik.</p>
                <div class="welcome-buttons">
                    <a href="<%= request.getContextPath() %>/bookings" class="btn-primary">View Bookings</a>
                    <a href="<%= request.getContextPath() %>/services" class="btn-secondary">Explore Services</a>
                </div>
            </div>

            <!-- Dashboard Card -->
            <div class="dashboard-card">
                <div class="card-header">
                    <div class="user-info">
                        <div class="user-avatar-text"><%= heroInitials %></div>
                        <div class="user-details">
                            <h3><%= vendorName %></h3>
                            <p><%= vendorBusiness %></p>
                        </div>
                    </div>
                    <span class="status-pill">
                        <svg width="8" height="8" fill="currentColor" viewBox="0 0 8 8">
                            <circle cx="4" cy="4" r="4"/>
                        </svg>
                        <%= isActive ? "Active" : "Pending" %>
                    </span>
                </div>
                <div class="earnings-box">
                    <div class="earnings-label">Total Earnings</div>
                    <div class="earnings-amount">₹<%= vendorEarnings %></div>
                    <div class="earnings-change">
                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        Lifetime revenue
                    </div>
                </div>
                <div class="quick-metrics">
                    <div class="metric">
                        <div class="metric-icon">
                            <svg fill="none" stroke="#1b376c" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div class="metric-value"><%= vendorBookingCount %></div>
                        <div class="metric-label">Bookings</div>
                    </div>
                    <div class="metric">
                        <div class="metric-icon">
                            <svg fill="none" stroke="#D4A574" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                            </svg>
                        </div>
                        <div class="metric-value"><%= vendorRating %>★</div>
                        <div class="metric-label">Rating</div>
                    </div>
                    <div class="metric">
                        <div class="metric-icon">
                            <svg fill="none" stroke="#10B981" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="metric-value"><%= isActive ? "Live" : "Off" %></div>
                        <div class="metric-label">Status</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Services Section -->
        <section id="services">
            <div class="section-header">
                <h2>Your Active Services</h2>
                <p><%= vendorCategory %> packages you offer</p>
            </div>
            <div class="services-grid">
                <% if (svcList.isEmpty()) { %>
                <div style="grid-column:1/-1;text-align:center;padding:60px 40px;background:var(--cream);border-radius:var(--radius-lg);border:1px dashed var(--border);">
                    <div style="font-size:20px;font-weight:700;color:var(--navy);margin-bottom:8px;font-family:'Playfair Display',serif;">No services added yet</div>
                    <div style="font-size:14px;color:var(--text-muted);margin-bottom:24px;">Add your services to start receiving bookings from clients.</div>
                    <a href="<%= request.getContextPath() %>/services" class="btn-primary">Add Services</a>
                </div>
                <% } else { %>
                <% for (Map<String, Object> svc : svcList) { %>
                <div class="service-card">
                    <img src="<%= svc.get("image") != null ? svc.get("image") : "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=800&h=600&fit=crop&q=90" %>" class="service-img" alt="<%= svc.get("name") %>">
                    <div class="service-body">
                        <span class="service-tag"><%= svc.get("category") != null ? svc.get("category") : "Service" %></span>
                        <h3><%= svc.get("name") %></h3>
                        <p><%= svc.get("description") != null ? svc.get("description") : "" %></p>
                        <div class="service-footer">
                            <span class="service-price">₹<%= svc.get("price") %></span>
                            <a href="<%= request.getContextPath() %>/services" class="service-link">Details →</a>
                        </div>
                    </div>
                </div>
                <% } %>
                <% } %>
            </div>
        </section>

        <!-- Portfolio Section -->
        <section id="portfolio">
            <div class="section-header">
                <h2>Portfolio Highlights</h2>
                <p>Showcasing exceptional <%= vendorCategory %> work</p>
            </div>
            <div class="portfolio-grid">
                <div class="portfolio-item">
                    <img src="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=600&h=800&fit=crop&q=90" alt="Work 1">
                    <div class="portfolio-overlay">
                        <h4>Wedding Shoot</h4>
                        <p>Featured Portfolio</p>
                    </div>
                </div>
                <div class="portfolio-item">
                    <img src="https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=600&h=800&fit=crop&q=90" alt="Work 2">
                    <div class="portfolio-overlay">
                        <h4>Professional Portraits</h4>
                        <p>Studio Session</p>
                    </div>
                </div>
                <div class="portfolio-item">
                    <img src="https://images.unsplash.com/photo-1591604129939-f1efa4d9f7fa?w=600&h=800&fit=crop&q=90" alt="Work 3">
                    <div class="portfolio-overlay">
                        <h4>Event Coverage</h4>
                        <p>Corporate Event</p>
                    </div>
                </div>
                <div class="portfolio-item">
                    <img src="https://images.unsplash.com/photo-1542038784456-1ea8e935640e?w=600&h=800&fit=crop&q=90" alt="Work 4">
                    <div class="portfolio-overlay">
                        <h4>Product Catalog</h4>
                        <p>Commercial Shoot</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Profile Section -->
        <section class="profile-section">
            <div class="section-header" style="text-align: left; margin-bottom: 24px;">
                <h2>My Profile</h2>
            </div>
            <div class="profile-grid">
                <div class="profile-field">
                    <div class="profile-field-label">Full Name</div>
                    <div class="profile-field-value"><%= vendorName %></div>
                </div>
                <div class="profile-field">
                    <div class="profile-field-label">Email Address</div>
                    <div class="profile-field-value"><%= userEmail != null ? userEmail : "N/A" %></div>
                </div>
                <div class="profile-field">
                    <div class="profile-field-label">Phone Number</div>
                    <div class="profile-field-value"><%= vendorPhone %></div>
                </div>
                <div class="profile-field">
                    <div class="profile-field-label">Service Category</div>
                    <div class="profile-field-value"><%= vendorCategory %></div>
                </div>
                <div class="profile-field">
                    <div class="profile-field-label">Business Name</div>
                    <div class="profile-field-value"><%= vendorBusiness %></div>
                </div>
                <div class="profile-field">
                    <div class="profile-field-label">Location</div>
                    <div class="profile-field-value"><%= vendorLocation %></div>
                </div>
            </div>
        </section>

        <!-- Bookings Section -->
        <section id="bookings" style="margin-top:48px;">
            <div class="section-header">
                <h2>Recent Bookings</h2>
                <p>Your latest client bookings and status</p>
            </div>
            <div class="dashboard-card">
                <% if (bkList.isEmpty()) { %>
                <div style="text-align:center;padding:48px 20px;background:var(--cream);border-radius:var(--radius);">
                    <div style="font-size:20px;font-weight:700;color:var(--navy);margin-bottom:8px;font-family:'Playfair Display',serif;">No Bookings Yet</div>
                    <div style="font-size:14px;color:var(--text-muted);">Your bookings will appear here once clients book your services.</div>
                </div>
                <% } else { %>
                <table class="bookings-table">
                    <thead>
                        <tr>
                            <th>Booking ID</th>
                            <th>Client</th>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for (Map<String, Object> bk : bkList) { %>
                        <% String bs = (String) bk.get("status"); %>
                        <tr>
                            <td class="bk-id">#<%= bk.get("id") %></td>
                            <td class="bk-client"><%= bk.get("client") %></td>
                            <td class="bk-event"><%= bk.get("event") %></td>
                            <td class="bk-date"><%= bk.get("date") %></td>
                            <td class="bk-amount">₹<%= bk.get("amount") %></td>
                            <td>
                                <span class="bk-status <%= bs != null ? bs.toLowerCase() : "pending" %>">
                                    <%= bk.get("status") %>
                                </span>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
                <% } %>
            </div>
        </section>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <h3>PRO<span>QIK</span></h3>
                    <p>India's leading platform connecting professional photographers and videographers with clients nationwide.</p>
                    <div class="social-links">
                        <a href="#" class="social-link">
                            <svg viewBox="0 0 24 24">
                                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                            </svg>
                        </a>
                        <a href="#" class="social-link">
                            <svg viewBox="0 0 24 24">
                                <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                            </svg>
                        </a>
                        <a href="#" class="social-link">
                            <svg viewBox="0 0 24 24">
                                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                            </svg>
                        </a>
                    </div>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="#dashboard">Dashboard</a></li>
                        <li><a href="#services">Services</a></li>
                        <li><a href="#portfolio">Portfolio</a></li>
                        <li><a href="#bookings">Bookings</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Contact Us</a></li>
                        <li><a href="#">FAQs</a></li>
                        <li><a href="#">Terms & Conditions</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Resources</h4>
                    <ul>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Photography Tips</a></li>
                        <li><a href="#">Pricing Guide</a></li>
                        <li><a href="#">Success Stories</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 PROQIK. All rights reserved. | Empowering photographers across India</p>
            </div>
        </div>
    </footer>

    <script>
        function toggleMenu() {
            const nav = document.getElementById('mainNav');
            nav.classList.toggle('active');
        }
    </script>
</body>
</html>